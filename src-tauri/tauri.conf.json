{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aura",
  "version": "0.1.0",
  "identifier": "com.fanhuaze.aura",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Aura",
        "width": 1280,
        "height": 850,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "resources": [
      "../bridge",
      "../skills",
      "../plugins"
    ]
  }
}

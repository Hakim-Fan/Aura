{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aura",
  "version": "0.1.1",
  "identifier": "com.hyfun.aura",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Aura",
        "width": 1280,
        "height": 850,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../bridge",
      "../skills"
    ],
    "macOS": {
      "entitlements": "Entitlements-macOS.plist"
    }
  }
}
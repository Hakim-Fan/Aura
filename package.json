{
  "name": "desk-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.1.1",
  "scripts": {
    "dev:web": "vite --host 0.0.0.0 --port 1420",
    "dev": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri dev",
    "build": "vite build",
    "build:bridge": "node scripts/build-bridge.mjs",
    "typecheck": "tsc --noEmit",
    "tauri:build": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri build",
    "desktop:dev": "pnpm dev",
    "desktop:web": "pnpm dev:web",
    "desktop:typecheck": "pnpm typecheck",
    "desktop:build": "pnpm tauri:build",
    "desktop:prepare-build": "pnpm build && pnpm build:bridge"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "^1.17.4",
    "@mozilla/readability": "^0.6.0",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.4.2",
    "@tauri-apps/plugin-http": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.3.0",
    "https-proxy-agent": "^9.0.0",
    "linkedom": "^0.18.12",
    "lucide-react": "^1.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.1",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.8.3",
    "unocss": "0.65.4",
    "vite": "^5.4.19"
  }
}
